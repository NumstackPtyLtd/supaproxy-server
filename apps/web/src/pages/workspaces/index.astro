---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import type { WorkspaceListItem } from '../../types';
import { logError } from '../../lib/logger';

const user = Astro.locals.user;

const API_URL = import.meta.env.PUBLIC_SUPAPROXY_API_URL;
if (!API_URL) throw new Error('Missing required environment variable: PUBLIC_SUPAPROXY_API_URL');
let workspaces: WorkspaceListItem[] = [];
let fetchError = '';
try {
  const res = await fetch(`${API_URL}/api/workspaces`);
  if (!res.ok) {
    logError('Workspaces API returned', res.status);
    fetchError = `Failed to load workspaces (HTTP ${res.status})`;
  } else {
    const data = await res.json();
    workspaces = data.workspaces || [];
  }
} catch (err) {
  logError('Failed to fetch workspaces:', err);
  fetchError = 'Unable to connect to the API. Please try again later.';
}

// Stats now come from the API (queries_today, cost_mtd are in each workspace object)
---

<Layout title="Workspaces - SupaProxy">
  <Header />
  <main class="pt-14 min-h-screen" style="background: var(--bg-card)">

    <div class="max-w-[960px] mx-auto px-6 py-6">
      <Breadcrumbs items={[{ label: 'Workspaces' }]} />

      <div class="flex items-center justify-between mb-5">
        <div>
          <h1 class="text-[18px] font-semibold" style="color: var(--text-heading)">Workspaces</h1>
          <p class="text-xs mt-0.5" style="color: var(--text-muted)">Manage your AI workspaces and their connections.</p>
        </div>
        <button class="px-3 py-1.5 rounded-sm text-[11px] font-medium transition-colors" style="color: var(--btn-primary-text); background: var(--btn-primary-bg)">
          New workspace
        </button>
      </div>

      {fetchError ? (
        <div class="py-12 text-center">
          <p class="text-xs mb-4" style="color: var(--color-danger)">{fetchError}</p>
          <a href="/workspaces" class="px-3 py-1.5 rounded text-[11px] font-medium transition-colors" style="color: var(--btn-primary-text); background: var(--btn-primary-bg)">
            Retry
          </a>
        </div>
      ) : workspaces.length === 0 ? (
        <div class="py-12 text-center">
          <p class="text-xs mb-4" style="color: var(--text-muted)">Create your first workspace to get started.</p>
          <button class="px-3 py-1.5 rounded text-[11px] font-medium transition-colors" style="color: var(--btn-primary-text); background: var(--btn-primary-bg)">
            New workspace
          </button>
        </div>
      ) : (
        <div>
          {/* Table header */}
          <div class="flex items-center gap-3 px-3 py-1.5 text-[10px] uppercase tracking-wide" style="color: var(--text-muted); border-bottom: 1px solid var(--border-color)">
            <span class="flex-1">Name</span>
            <span class="w-24">Team</span>
            <span class="w-20 text-right">Connections</span>
            <span class="w-24 text-right">Queries today</span>
            <span class="w-20 text-right">Cost MTD</span>
            <span class="w-4"></span>
          </div>
          {/* Table rows */}
          {workspaces.map((ws) => (
            <a href={`/workspaces/${ws.id}`} class="flex items-center gap-3 px-3 py-2 transition-colors group" style={`border-bottom: 1px solid var(--border-color)`}>
              <div class="flex-1 flex items-center gap-2 min-w-0">
                <span class="text-xs font-medium transition-colors truncate" style="color: var(--text-heading)">{ws.name}</span>
                <span class={`inline-block px-1.5 py-0.5 rounded-full text-[10px] font-medium leading-none ${ws.status === 'active' ? 'bg-green-50 text-green-700' : ''}`} style={ws.status !== 'active' ? 'background: var(--bg-hover); color: var(--text-muted)' : ''}>{ws.status || 'active'}</span>
              </div>
              <span class="w-24 text-[11px] truncate" style="color: var(--body)">{ws.team}</span>
              <span class="w-20 text-[11px] text-right font-mono" style="color: var(--body)">{ws.tool_count || 0}</span>
              <span class="w-24 text-[11px] text-right font-mono" style="color: var(--body)">{ws.queries_today || 0}</span>
              <span class="w-20 text-[11px] text-right font-mono" style="color: var(--body)">${parseFloat(ws.cost_mtd || 0).toFixed(2)}</span>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 flex-shrink-0" style="color: var(--text-muted)">
                <path d="M9 18l6-6-6-6"/>
              </svg>
            </a>
          ))}
        </div>
      )}
    </div>
  </main>
  <Footer />
</Layout>
