---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<nav class="flex items-center gap-1.5 text-[11px] mb-4">
  {items.map((item, i) => (
    <>
      {i > 0 && <span class="text-[#666]">/</span>}
      {item.href ? (
        <a href={item.href} class="text-[#666] hover:text-white transition-colors">{item.label}</a>
      ) : (
        <span class="text-white font-medium">{item.label}</span>
      )}
    </>
  ))}
</nav>
