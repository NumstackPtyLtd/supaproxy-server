---
import CapabilitiesGrid from './CapabilitiesGrid';
---

<!-- Integrations -->
<section class="py-12 bg-[#0a0a0a]">
  <div class="max-w-[960px] mx-auto px-6">
    <p class="text-[11px] text-[#666] uppercase tracking-[0.15em] font-medium text-center mb-6">Works with</p>
    <div class="flex items-center justify-center gap-10 opacity-60 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-500">
      <img src="/integrations/slack.png" alt="Slack" class="h-10" />
      <img src="/integrations/whatsapp.webp" alt="WhatsApp" class="h-10 rounded-lg" />
      <img src="/integrations/confluence.svg" alt="Confluence" class="h-10" />
      <div class="flex items-center gap-2 text-[13px] text-[#666]">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
        <span>MCP</span>
      </div>
      <div class="flex items-center gap-2 text-[13px] text-[#666]">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        <span>REST APIs</span>
      </div>
    </div>
  </div>
</section>

<!-- Problem section -->
<section class="py-20 bg-[#0a0a0a]">
  <div class="max-w-[960px] mx-auto px-6">
    <p class="text-[11px] text-white uppercase tracking-[0.15em] font-semibold mb-3">The problem</p>
    <h2 class="text-[30px] font-bold text-white leading-tight mb-10 max-w-[500px]">Without governance, AI becomes a liability.</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <div class="bg-[#1a1a1a] rounded-xl p-6">
        <div class="w-10 h-10 rounded-lg bg-[#111] flex items-center justify-center mb-4">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-white" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <h3 class="text-[15px] font-semibold text-white mb-2">Invisible spend</h3>
        <p class="text-[13px] text-[#a1a1a1] leading-relaxed">AI costs scattered across team budgets. No central view. Overruns found after the invoice.</p>
      </div>

      <div class="bg-[#111] rounded-xl p-6">
        <div class="w-10 h-10 rounded-lg bg-[#111] flex items-center justify-center mb-4">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F59E0B" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3 class="text-[15px] font-semibold text-white mb-2">No compliance layer</h3>
        <p class="text-[13px] text-[#a1a1a1] leading-relaxed">Each team handles PII differently. No audit trail. Security has no single answer.</p>
      </div>

      <div class="bg-[#1a1a1a] rounded-xl p-6">
        <div class="w-10 h-10 rounded-lg bg-[#111] flex items-center justify-center mb-4">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-white" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
        </div>
        <h3 class="text-[15px] font-semibold text-white mb-2">Fragmented tooling</h3>
        <p class="text-[13px] text-[#a1a1a1] leading-relaxed">Five teams build five bots. Five auth systems, five logging setups. Duplicated effort everywhere.</p>
      </div>
    </div>
  </div>
</section>

<!-- Capabilities grid -->
<section class="py-20 bg-[#111]">
  <div class="max-w-[960px] mx-auto px-6">
    <p class="text-[11px] text-white uppercase tracking-[0.15em] font-semibold mb-3">Platform</p>
    <h2 class="text-[30px] font-bold text-white leading-tight mb-10">Teams bring the data. SupaProxy handles the rest.</h2>

    <CapabilitiesGrid client:load />
  </div>
</section>

<!-- CTA -->
<section class="py-20 bg-[#0a0a0a]">
  <div class="max-w-[480px] mx-auto px-6 text-center">
    <h2 class="text-[26px] font-bold text-white mb-3">Your first query in five minutes.</h2>
    <p class="text-[15px] text-[#a1a1a1] mb-8">Sign up, connect a data source, ask a question.</p>
    <a href="/signup" class="inline-block px-8 py-3.5 rounded-lg text-[14px] font-semibold text-white bg-black hover:bg-[#1A1A1A] transition-all shadow-lg shadow-black/5">
      Get started free
    </a>
  </div>
</section>
