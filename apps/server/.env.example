# Required — server will not start without these.
# All secrets (AI keys, Slack tokens) are configured in the dashboard under Settings.

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=

# Server
PORT=3001
CORS_ORIGINS=http://localhost:4322,http://localhost:3001
DASHBOARD_URL=http://localhost:4322

# MySQL (match docker-compose.yaml)
DB_HOST=127.0.0.1
DB_PORT=3308
DB_USER=root
DB_PASSWORD=
DB_NAME=supaproxy

# Redis (match docker-compose.yaml)
REDIS_HOST=127.0.0.1
REDIS_PORT=6380

# Audit logs
SUPAPROXY_LOG_DIR=./var/logs

# Default model for new workspaces (e.g. claude-sonnet-4-20250514, gpt-4o, etc.)
DEFAULT_MODEL=

# Optional: Azure AD SSO (required only if using Azure AD auth)
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_REDIRECT_URI=
