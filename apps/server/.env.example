# Local dev — server runs on host, MySQL/Redis in Docker.
# This file is for apps/server/.env (local dev).
# The root .env is for docker-compose (uses service names and internal ports).
#
# Required — server will not start without these.
# AI keys and Slack tokens are configured at runtime via Settings.

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=

# Server
PORT=3001
CORS_ORIGINS=http://localhost:4322,http://localhost:3001
DASHBOARD_URL=http://localhost:4322

# MySQL (Docker mapped to host port 3308)
# DB_PASSWORD must match MYSQL_ROOT_PASSWORD in the container.
# Check with: docker inspect supaproxy-mysql --format '{{range .Config.Env}}{{println .}}{{end}}' | grep MYSQL_ROOT
DB_HOST=127.0.0.1
DB_PORT=3308
DB_USER=root
DB_PASSWORD=
DB_NAME=supaproxy

# Redis (Docker mapped to host port 6380)
REDIS_HOST=127.0.0.1
REDIS_PORT=6380

# Audit logs
SUPAPROXY_LOG_DIR=./var/logs

# Optional: Azure AD SSO
# AZURE_AD_TENANT_ID=
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_REDIRECT_URI=
