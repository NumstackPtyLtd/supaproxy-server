# Root .env — used by docker-compose for the full Docker setup.
# For local dev (server on host), use apps/server/.env instead.
#
# Generate secrets:
#   JWT_SECRET:  openssl rand -hex 32
#   DB_PASSWORD: openssl rand -hex 16

# Auth
JWT_SECRET=
DB_PASSWORD=

# Server
PORT=3001
CORS_ORIGINS=http://localhost:3001

# MySQL (internal Docker network)
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_NAME=supaproxy

# Redis (internal Docker network)
REDIS_HOST=redis
REDIS_PORT=6379

# Audit logs
SUPAPROXY_LOG_DIR=./var/logs
